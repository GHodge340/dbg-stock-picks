# Watchlist Analyst Configuration
GEMINI_API_KEY=your_gemini_api_key_here
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Log Source: LOCAL (if running on same machine) or REMOTE (if fetching via SSH)
